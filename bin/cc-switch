#!/usr/bin/env bash
# cc-switch — Claude Code provider switcher (standalone script for ! prefix)
#
# Self-locates the install root so this works whether invoked directly,
# via symlink, or from a dev checkout.
_cc_self="${BASH_SOURCE[0]:-$0}"
while [ -L "$_cc_self" ]; do _cc_self="$(readlink -f "$_cc_self")"; done
_cc_self_dir="$(cd "$(dirname "$_cc_self")" && pwd)"
CC_KIT_DIR="${CC_KIT_DIR:-$_cc_self_dir/..}"
CC_KIT_DIR="$(cd "$CC_KIT_DIR" && pwd)"
unset _cc_self _cc_self_dir

source "$CC_KIT_DIR/modules/switch.sh" 2>/dev/null
cc-switch "$@"
