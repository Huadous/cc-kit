#!/usr/bin/env bash
# cc-mode — Switch cc-kit statusLine display mode
# Usage: cc-mode [single|wide|full]
# See install.sh for why this is conditional.
set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

# Self-locate the install root. Falls back to $CC_KIT_DIR env var if set.
_cc_self="${BASH_SOURCE[0]:-$0}"
while [ -L "$_cc_self" ]; do _cc_self="$(readlink -f "$_cc_self")"; done
_cc_self_dir="$(cd "$(dirname "$_cc_self")" && pwd)"
CC_KIT_DIR="${CC_KIT_DIR:-$_cc_self_dir/..}"
CC_KIT_DIR="$(cd "$CC_KIT_DIR" && pwd)"
unset _cc_self _cc_self_dir

MODE_FILE="$CC_KIT_DIR/data/.display_mode"
mkdir -p "$(dirname "$MODE_FILE")"

mode="${1:-}"

show_modes() {
  local current="${CC_KIT_DISPLAY_MODE:-single}"
  if [[ -f "$MODE_FILE" ]]; then
    current=$(cat "$MODE_FILE")
  fi
  echo "cc-kit display modes:"
  for m in single wide full; do
    if [[ "$m" == "$current" ]]; then
      echo "  ◆ $m  ← current"
    else
      echo "    $m"
    fi
  done
  echo ""
  echo "Usage: cc-mode [single|wide|full]"
}

case "$mode" in
  single|wide|full)
    echo "$mode" > "$MODE_FILE"
    echo "✓ Display mode set to: $mode"
    echo "  Run /reload-plugins in Claude Code to apply."
    ;;
  show|"")
    show_modes
    ;;
  *)
    echo "Unknown mode: $mode" >&2
    show_modes
    exit 1
    ;;
esac
