#!/usr/bin/env bash
# cc-status — Unified Claude Code statusLine (single / wide / full layouts)
#
# Modes:
#   cc-status              single-line (default, always visible)
#   cc-status --wide       2-line left-right layout
#   cc-status --full       3-line boxed dashboard
#   cc-status --help
#
# Set default mode in settings.json statusLine command: "cc-status --wide"
# See install.sh for why this is conditional.
set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

# Self-locate: works whether invoked directly, via symlink, or from a dev checkout.
# Falls back to $CC_KIT_DIR env var if set so the user's dev override still works.
_cc_self="${BASH_SOURCE[0]:-$0}"
while [ -L "$_cc_self" ]; do _cc_self="$(readlink -f "$_cc_self")"; done
_cc_self_dir="$(cd "$(dirname "$_cc_self")" && pwd)"
CC_KIT_DIR="${CC_KIT_DIR:-$_cc_self_dir/..}"
CC_KIT_DIR="$(cd "$CC_KIT_DIR" && pwd)"
unset _cc_self _cc_self_dir

source "$CC_KIT_DIR/modules/monitor.sh" 2>/dev/null || true

# ── ANSI ────────────────────────────────────────────────────────────
R='\033[0m' B='\033[1m' D='\033[2m'
BLUE='\033[34m' GREEN='\033[32m' CYAN='\033[36m'
MAGENTA='\033[35m' YELLOW='\033[33m' RED='\033[31m' GRAY='\033[90m'

# ── Parse stdin (save for Python full mode passthrough) ────────────
STDIN_JSON="{}"
ctx_pct=""
if [[ -p /dev/stdin ]] || [[ ! -t 0 ]]; then
  STDIN_JSON=$(cat 2>/dev/null | head -1 || echo "{}")
  ctx_pct=$(echo "$STDIN_JSON" | grep -o '"remaining_percentage":[0-9.]*' 2>/dev/null | cut -d: -f2 | cut -d. -f1 || echo "")
fi

# ── Gather all data once ────────────────────────────────────────────
# Always source provider.env fresh so the displayed model matches the
# config on disk (Claude Code's own env vars are frozen at process start
# and cannot be refreshed mid-session).
if [[ -f "$CC_KIT_DIR/data/provider.env" ]]; then
  # shellcheck disable=SC1090
  source "$CC_KIT_DIR/data/provider.env"
fi
label=$(monitor_provider_label 2>/dev/null || echo "CC")
full_model="${ANTHROPIC_MODEL:-unknown}"
stats=$(monitor_stats_line 2>/dev/null || echo "0 0 0 0 0")
read -r in_tok out_tok cache_read _ <<< "$stats"
total_tok=$((in_tok + out_tok))

hit_s=$(monitor_hit_rate 2>/dev/null || echo "")
hit_g=$(monitor_global_hit_rate 2>/dev/null || echo "")
cost_s=$(monitor_session_cost 2>/dev/null || echo "")
cost_g=$(monitor_global_cost 2>/dev/null || echo "")
cur=$(monitor_currency 2>/dev/null || echo '$')
bal=$(monitor_cached_balance 2>/dev/null | awk '{print $1}' || echo "")

in_fmt=$(monitor_fmt_num "$in_tok")
out_fmt=$(monitor_fmt_num "$out_tok")
total_fmt=$(monitor_fmt_num "$total_tok")

# ── Context bar (10-seg, 8-level gradient) ──────────────────────────
ctx_bar10=""
if [[ -n "$ctx_pct" && "$ctx_pct" != "100" ]]; then
  u=$(( 100 - ctx_pct ))
  blocks=(' ' '▁' '▂' '▃' '▄' '▅' '▆' '▇' '█')
  for ((i=0; i<10; i++)); do
    ss=$(( i * 10 ))
    if (( u >= ss + 10 )); then lv=8
    elif (( u <= ss )); then lv=0
    else lv=$(( (u - ss) * 8 / 10 + 1 )); fi
    ctx_bar10+="${blocks[$lv]}"
  done
  if (( u > 75 )); then cb="$RED"
  elif (( u > 50 )); then cb="$YELLOW"
  else cb="$GREEN"; fi
  ctx_bar10="${cb}${ctx_bar10}${R}"
fi
ctx_label=""
[[ -n "$ctx_pct" && "$ctx_pct" != "100" ]] && ctx_label="${ctx_bar10} ${D}${ctx_pct}%${R}"

# ── Cost string ─────────────────────────────────────────────────────
cost_label=""
if [[ -n "$cost_s" && "$cost_s" != "0.00" ]]; then
  cost_label="${YELLOW}${cur}${cost_s}${R}"
  [[ -n "$cost_g" && "$cost_g" != "0.00" && "$cost_g" != "$cost_s" ]] && \
    cost_label+="${D}/${cur}${cost_g}${R}"
fi

# ── Balance ─────────────────────────────────────────────────────────
# Two shapes:  "30.77 CNY" (DeepSeek pay-as-you-go)
#              "96%  5h:4h02m  wk:100%"  (MiniMax coding plan)
bal_label=""
if [[ -n "$bal" ]]; then
  if [[ "$bal" == *%* ]]; then
    # Coding plan: color by interval percent
    interval_pct=$(echo "$bal" | grep -oE '^[0-9]+%' | tr -d '%')
    bc="$GREEN"
    [[ -n "$interval_pct" ]] && (( interval_pct < 20 )) && bc="$RED"
    [[ -n "$interval_pct" ]] && (( interval_pct >= 20 && interval_pct < 50 )) && bc="$YELLOW"
    # Compact: just the 5h % — full detail lives in !cc-balance
    bal_label="${bc}${interval_pct}% 5h${R}"
  elif [[ "$bal" != "0.00" ]]; then
    bn=$(echo "$bal" | sed 's/[^0-9.]//g')
    bc="$GREEN"
    (( $(echo "$bn < 10" | bc -l 2>/dev/null) )) && bc="$RED"
    (( $(echo "$bn >= 10 && $bn < 30" | bc -l 2>/dev/null) )) && bc="$YELLOW"
    bal_label="${bc}${cur}${bal}${R}"
  fi
fi

# ── Hit rate ────────────────────────────────────────────────────────
hit_label=""
if [[ -n "$hit_s" && "$hit_s" != "0" ]]; then
  hit_label="${MAGENTA}↯${hit_s}%${R}"
  [[ -n "$hit_g" && "$hit_g" != "0" && "$hit_g" != "$hit_s" ]] && \
    hit_label+="${D}/${hit_g}%${R}"
fi

# ── Provider badge ──────────────────────────────────────────────────
badge="${B}${CYAN}◆ ${label}${R}"

# ═════════════════════════════════════════════════════════════════════
# MODE: single (default) — 1 compact line
# ═════════════════════════════════════════════════════════════════════
render_single() {
  local line="${badge}"
  [[ -n "$ctx_label" ]] && line+=" ${GRAY}│${R} ${ctx_label} ctx"
  line+=" ${GRAY}│${R} ${BLUE}⬇${in_fmt}${R} ${GREEN}⬆${out_fmt}${R}"
  [[ -n "$hit_label" ]] && line+=" ${GRAY}│${R} ${hit_label} hit"
  [[ -n "$cost_label" ]] && line+=" ${GRAY}│${R} ${cost_label}"
  [[ -n "$bal_label" ]] && line+=" ${GRAY}│${R} ${bal_label}"
  printf '%b' "$line"
}

# ═════════════════════════════════════════════════════════════════════
# MODE: wide — 2-line left-right layout
# ═════════════════════════════════════════════════════════════════════
render_wide() {
  # Line 1: Provider + model · cost · balance
  local l1="${badge}  ${B}${full_model}${R}"
  [[ -n "$cost_label" ]] && l1+="  ·  ${cost_label}"
  [[ -n "$bal_label" ]] && l1+="  ·  ${bal_label}"
  printf '%b\n' "$l1"

  # Line 2: Tokens + hit rate + context bar
  local l2="  ${BLUE}⬇${in_fmt} input${R}  ${GREEN}⬆${out_fmt} output${R}  ${B}${total_fmt} total${R}"
  [[ -n "$hit_label" ]] && l2+="  ${hit_label}"
  [[ -n "$ctx_label" ]] && l2+="  ${ctx_label}"
  printf '%b' "$l2"
}

# ═════════════════════════════════════════════════════════════════════
# MODE: full — Python rendered boxed dashboard (proper ANSI width)
# ═════════════════════════════════════════════════════════════════════
render_full() {
  echo "$STDIN_JSON" | python3 "$CC_KIT_DIR/bin/cc-status-full.py" 2>/dev/null
}

# ── Mode dispatch (from config file or argument) ────────────────────
MODE_FILE="$CC_KIT_DIR/data/.display_mode"
mode="${1:-}"
# If no arg, read from saved mode file, fallback to single
if [[ -z "$mode" ]]; then
  if [[ -f "$MODE_FILE" ]]; then
    mode=$(cat "$MODE_FILE" 2>/dev/null || echo "single")
  else
    mode="single"
  fi
fi

case "$mode" in
  single) render_single ;;
  wide)   render_wide ;;
  full)   render_full ;;
  -h|--help)
    echo "cc-status [single|wide|full]  — Claude Code statusLine display modes"
    echo "  single  1-line compact (default)"
    echo "  wide    2-line left-right"
    echo "  full    3-line boxed dashboard"
    echo ""
    echo "Use 'cc-mode [single|wide|full]' to switch without editing settings.json"
    echo "  single  1-line compact (default)"
    echo "  wide    2-line left-right"
    echo "  full    3-line boxed dashboard"
    echo ""
    echo "Use 'cc-mode full' to switch, then /reload-plugins"
    ;;
  *) render_single ;;
esac
